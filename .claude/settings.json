{
  "model": "claude-opus-4-6[1m]",
  "effortLevel": "high",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(./.claude/scripts/check-env-readonly.sh)",
      "Bash(./.claude/hooks/run-env-readonly.sh)",
      "Bash(bash ./.claude/hooks/run-env-readonly.sh)",
      "Bash(./.claude/hooks/run-env-readonly.ps1)",
      "Bash(& '.claude/hooks/run-env-readonly.ps1')",
      "Bash(pwsh -File ./.claude/hooks/run-env-readonly.ps1)",
      "Bash(./.claude/hooks/run-bq-readonly.sh)",
      "Bash(bash ./.claude/hooks/run-bq-readonly.sh)",
      "Bash(./.claude/hooks/run-bq-readonly.ps1)",
      "Bash(& '.claude/hooks/run-bq-readonly.ps1')",
      "Bash(pwsh -File ./.claude/hooks/run-bq-readonly.ps1)"
    ],
    "deny": [
      "Bash(bq rm *)",
      "Bash(bq mk *)",
      "Bash(bq load *)",
      "Bash(bq insert *)",
      "Bash(bq cp *)",
      "Bash(bq update *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/bq-query-guard.sh"
          }
        ]
      },
      {
        "matcher": "Read|Glob|Grep|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/sync-main.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "slack@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true
  }
}
